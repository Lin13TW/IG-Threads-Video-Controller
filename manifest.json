{
  "manifest_version": 3,
  "name": "Threads Video Pro",
  "version": "1.4",
  "description": "v14.3: IG expanded post fix - small modal vs large post dialog",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "*://*.threads.net/*",
    "*://*.threads.com/*",
    "*://*.instagram.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.threads.net/*",
        "*://*.threads.com/*",
        "*://*.instagram.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}